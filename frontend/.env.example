# OAuth client ID from Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=

# Google Sheet ID (from the sheet URL: docs.google.com/spreadsheets/d/<THIS_ID>/edit)
VITE_SPREADSHEET_ID=

# Set to "true" to skip Google auth and use sample data (no GCP setup needed)
VITE_DEMO_MODE=
